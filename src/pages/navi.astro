---
// index.astro
import "../style/navi.css"
import "../style/searchwidget.css"
import Layout from "../layouts/Layout.astro"
---
<Layout>
	<div class="box">
		<div class="top">
			<p> NAVI </p>
		</div>
		<div class="bottom">
            <!-- 搜索组件容器 -->
			<div class="search-widget" id="searchWidget">
				<!-- 搜索引擎切换器 (下拉式) -->
				<div class="engine-selector">
					<button type="button" class="engine-btn" id="engineBtn" aria-haspopup="true" aria-expanded="false">
						<span class="engine-icon" id="currentEngineIcon">🔍</span>
						<span class="engine-name" id="currentEngineName">Bing</span>
						<svg class="arrow-icon" viewBox="0 0 24 24" width="16" height="16">
							<path fill="currentColor" d="M7 10l5 5 5-5z"></path>
						</svg>
					</button>
					<!-- 下拉菜单列表 -->
					<ul class="engine-list" id="engineList" role="menu">
						<!-- 列表项将通过 JS 动态生成，或者静态写死如下 -->
						<li data-engine="bing" role="menuitem">
							<span class="icon">🔍</span> Bing
						</li>
						<li data-engine="google" role="menuitem">
							<span class="icon">G</span> Google
						</li>
						<!-- 拓展空间：未来可直接在此添加更多 li，或在 JS 配置中添加 -->
					</ul>
				</div>

				<!-- 搜索输入区域 -->
				<form class="search-form" id="searchForm" action="" method="GET" target="_blank">
					<input 
						type="text" 
						class="search-input" 
						id="searchInput" 
						placeholder="Search with Bing..." 
						autocomplete="off"
						required
					>
					<button type="submit" class="search-submit-btn">
						<svg viewBox="0 0 24 24" width="20" height="20">
							<path fill="currentColor" d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"></path>
						</svg>
					</button>
				</form>
			</div>
		</div>
	<script type="module" src="/src/scripts/intro.js"></script>
	<script type="module" src="/src/scripts/search.js"></script>
</Layout>